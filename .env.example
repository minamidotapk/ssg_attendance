# Client-side Firebase (NEXT_PUBLIC_* is bundled into the browser)
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=

# Firebase Admin (server only) — verifies ID tokens; same Firebase project as NEXT_PUBLIC_*
# Option A: one line of JSON (do NOT break across lines in .env — dotenv will truncate). Or run: node scripts/fix-firebase-env-json.mjs
FIREBASE_SERVICE_ACCOUNT_JSON=
# Option B: path to the downloaded JSON file (gitignored example: firebase-adminsdk.local.json)
# FIREBASE_SERVICE_ACCOUNT_PATH=firebase-adminsdk.local.json
# Option C: split fields (Vercel-friendly; use \n for newlines inside the private key string)
# FIREBASE_ADMIN_PROJECT_ID=
# FIREBASE_ADMIN_CLIENT_EMAIL=
# FIREBASE_ADMIN_PRIVATE_KEY=

# MongoDB Atlas (server only — never NEXT_PUBLIC_)
# Use the SRV string from Atlas → Connect → Drivers. In Atlas → Network Access, allow 0.0.0.0/0 (or Vercel egress) for serverless.
# If the DB password has @ # etc., URL-encode it in the URI. No extra quotes around the value in Vercel.
MONGODB_URI=
# Optional: database name (defaults to ssg_attendance)
MONGODB_DB=ssg_attendance
# IANA timezone for stored date/time fields (use Asia/Manila for Philippines)
ATTENDANCE_TIMEZONE=Asia/Manila

# Optional: extra admin emails (comma-separated). Default includes ssg20252026@gmail.com in code.
# ADMIN_EMAILS=teacher@school.edu

# Optional: identify your app for OpenStreetMap Nominatim reverse geocoding (recommended in production)
# NOMINATIM_USER_AGENT=https://yourdomain.com/contact
